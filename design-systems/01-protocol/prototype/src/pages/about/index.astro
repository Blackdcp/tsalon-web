---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const partners = (await getCollection('partners')).sort((a, b) => a.data.order - b.data.order);
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Organization', name: 'T Salon', alternateName: 'T 技术沙龙',
  foundingDate: '2016-03', url: 'https://www.tsalon.tech/',
  description: '面向开发者的线上与线下技术交流平台。',
  member: team.map((member) => ({ '@type': 'Person', name: member.data.handle ? `${member.data.handle}（${member.data.name}）` : member.data.name, jobTitle: member.data.role })),
  sameAs: ['https://github.com/Code-T', 'https://space.bilibili.com/488340243'],
};
---
<BaseLayout alternatePath="/en/about/" title="关于 T Salon — 始于 2016 的开发者技术社区" description="T Salon 始于 2016 年，由开发者发起并共同建设，长期组织 Apple 开发者生态、AI 技术与商业、具身智能等线上与线下活动。" image="/images/gallery/gallery-17.jpeg" jsonLd={jsonLd}>
  <main>
    <header class="container about-hero"><div><p class="eyebrow">关于 / T SALON</p><h1>&lt; 从开发者中来<br />到真实问题中去 &gt;</h1></div><div><p>我们深度理解技术趋势与开发者需求。T Salon 不以某个技术栈定义自己，而以高质量内容、真实交流和长期社区关系连接开发者。</p></div></header>

    <section class="about-stats"><div class="container"><div><strong>2016</strong><span>社区成立</span></div><div><strong>100+</strong><span>累计线下活动</span></div><div><strong>10万+</strong><span>服务开发者</span></div><div><strong>50+</strong><span>合作科技企业与社区</span></div></div></section>

    <section class="container about-story"><aside><span class="mono">01 / 我们是谁</span></aside><div><h2>从 iOS 开发者组织，发展为面向下一代技术的开放社区</h2><p>T 技术沙龙成立于 2016 年 3 月，最早由一群 iOS 开发者发起。社区从 Apple 开发者生态出发，逐步扩展到 AI 技术与商业、具身智能，以及更广泛的工程实践。</p><p>我们在北京、上海、深圳、广州、杭州等城市持续组织线下活动，也通过直播、访谈和在线圆桌让讨论跨越城市。技术主题会变化，但我们始终关心：正在做事的人遇到了什么问题，又做出了怎样的选择。</p></div></section>

    <section class="container partner-section"><header class="section-heading"><span class="mono">02 / 社区伙伴</span><h2>社区不是独立完成的</h2><p class="section-note">以下为 T Salon 历年合作企业、开发者社区、媒体与出版伙伴。</p></header><div class="partner-logo-grid">{partners.map((partner) => <figure><img src={partner.data.logo} alt={partner.data.logoAlt} loading="lazy" /><figcaption>{partner.data.name}</figcaption></figure>)}</div></section>

    <section class="container about-history-link"><figure><img src="/images/gallery/gallery-12.jpeg" alt="2017 年 T Salon 与饿了么合作活动现场" loading="lazy" /></figure><div><p class="eyebrow">社区年鉴</p><h2>九年不是一个数字<br />而是一连串真实现场</h2><p>社区年鉴收录 2016 年以来的活动照片与城市轨迹。每一张照片，都来自开发者真正见面和交流的现场。</p><a class="btn btn-dark" href="/history/">进入社区年鉴 <span>→</span></a></div></section>

    <section class="about-next-section" id="join"><div class="container about-next-history"><div><p class="eyebrow">下一段 / 社区</p><h2>下一段社区历史<br />希望有你</h2><p>从三位发起者，到更多愿意分享经验、促成交流、一起把事情做成的人。社区的下一页，仍然由真实参与者写下。</p></div><div class="about-founder-signature"><div class="about-founder-heads" aria-label="T Salon 三位发起者">{team.map((member) => <img src={member.data.avatar} alt={member.data.handle || member.data.name} loading="lazy" />)}<span aria-hidden="true">＋</span></div><p><strong>MM · EyreFree · Black</strong><br />和下一位社区共建者</p><a href="#participate">看看如何参与 <span>↓</span></a></div></div></section>

    <section class="about-participate" id="participate">
      <div class="container">
        <header class="about-participate-header">
          <div><p class="eyebrow">03 / 一起做点事情</p><h2>一起做点事情</h2></div>
          <p>活动看公众号，合作找 Black；代码与视频，直接打开对应主页。</p>
        </header>
        <div class="about-channel-grid">
          <article class="about-channel-card" id="official">
            <p class="eyebrow">活动</p><h3>关注公众号</h3><p>活动发布与报名</p>
            <figure><img src="/images/connect/wechat-official.jpg" alt="T Salon 微信公众号二维码" /><figcaption>微信扫码</figcaption></figure>
          </article>
          <article class="about-channel-card" id="cooperate">
            <p class="eyebrow">合作</p><h3>联系 Black</h3><p>嘉宾、主办、品牌与内容合作</p>
            <figure><img src="/images/connect/wechat-cooperation-qr.png" alt="Black 合作微信二维码" /><figcaption>微信扫码</figcaption></figure>
          </article>
          <a class="about-channel-card about-channel-link" href="https://github.com/Code-T" target="_blank" rel="noreferrer">
            <p class="eyebrow">开源</p><h3>GitHub<br />Code-T</h3><p>开源项目与社区资料</p><span>打开主页 ↗</span>
          </a>
          <a class="about-channel-card about-channel-link" href="https://space.bilibili.com/488340243" target="_blank" rel="noreferrer">
            <p class="eyebrow">视频</p><h3>bilibili<br />T Salon</h3><p>活动视频与内容存档</p><span>打开主页 ↗</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
