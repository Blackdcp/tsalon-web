---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { partnerEn } from '../../../data/en';
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const partners = (await getCollection('partners')).sort((a, b) => a.data.order - b.data.order);
const jsonLd = { '@context': 'https://schema.org', '@type': 'Organization', name: 'T Salon', foundingDate: '2016-03', url: 'https://www.tsalon.tech/en/', description: 'An online and offline technology community built by developers.', sameAs: ['https://github.com/Code-T', 'https://space.bilibili.com/488340243'] };
---
<BaseLayout locale="en" alternatePath="/about/" title="About T Salon — A developer community since 2016" description="T Salon began as an iOS developer group in 2016 and now connects real practice across the Apple ecosystem, AI, embodied intelligence and engineering." image="/images/gallery/gallery-17.jpeg" jsonLd={jsonLd}>
  <main>
    <header class="container about-hero"><div><p class="eyebrow">ABOUT / T SALON</p><h1>&lt; From developers<br />towards real problems &gt;</h1></div><div><p>We connect developers through strong content, candid exchange and long-term community relationships. T Salon is not defined by a single technology stack.</p></div></header>
    <section class="about-stats"><div class="container"><div><strong>2016</strong><span>Founded</span></div><div><strong>100+</strong><span>In-person events</span></div><div><strong>100K+</strong><span>Developers reached</span></div><div><strong>50+</strong><span>Technology and community partners</span></div></div></section>
    <section class="container about-story"><aside><span class="mono">01 / WHO WE ARE</span></aside><div><h2>From an iOS developer group to an open community for what comes next</h2><p>T Salon was founded in March 2016 by a group of iOS developers. Starting with the Apple developer ecosystem, the community gradually expanded into AI technology and business, embodied intelligence and wider engineering practice.</p><p>We have organised gatherings in Beijing, Shanghai, Shenzhen, Guangzhou and Hangzhou, while livestreams, interviews and online roundtables carry conversations across cities. The technologies change; our question stays the same: what problems are practitioners facing, and what choices are they making?</p></div></section>
    <section class="container partner-section"><header class="section-heading"><span class="mono">02 / FRIENDS & PARTNERS</span><h2>No community is built alone</h2><p class="section-note">Technology companies, developer groups, media and publishing partners we have worked with over the years.</p></header><div class="partner-logo-grid">{partners.map((partner) => <figure><img src={partner.data.logo} alt={partnerEn[partner.id] ?? partner.data.name} loading="lazy" /><figcaption>{partnerEn[partner.id] ?? partner.data.name}</figcaption></figure>)}</div></section>
    <section class="container about-history-link"><figure><img src="/images/gallery/gallery-12.jpeg" alt="Developers at a T Salon event in 2017" loading="lazy" /></figure><div><p class="eyebrow">COMMUNITY ARCHIVE</p><h2>Nine years is not a number<br />It is a chain of real rooms</h2><p>The community archive follows the people, cities and gatherings that have shaped T Salon since 2016.</p><a class="btn btn-dark" href="/en/history/">Enter the archive <span>→</span></a></div></section>
    <section class="about-next-section" id="join"><div class="container about-next-history"><div><p class="eyebrow">NEXT / COMMUNITY</p><h2>There is room for you in the next chapter</h2><p>What began with three founders continues through people who share experience, create connections and help make useful things happen.</p></div><div class="about-founder-signature"><div class="about-founder-heads" aria-label="Three T Salon founders">{team.map((member) => <img src={member.data.avatar} alt={member.data.handle || member.data.name} loading="lazy" />)}<span aria-hidden="true">＋</span></div><p><strong>MM · EyreFree · Black</strong><br />and the next community builder</p><a href="#participate">Ways to take part <span>↓</span></a></div></div></section>
    <section class="about-participate" id="participate"><div class="container"><header class="about-participate-header"><div><p class="eyebrow">03 / DO SOMETHING TOGETHER</p><h2>Let’s make something useful</h2></div><p>Follow the official account for events, contact Black for collaboration, or open our code and video channels directly.</p></header><div class="about-channel-grid">
      <article class="about-channel-card" id="official"><p class="eyebrow">EVENTS</p><h3>Follow T Salon<br />on WeChat</h3><p>Event announcements and registration</p><figure><img src="/images/connect/wechat-official.jpg" alt="T Salon official WeChat account QR code" /><figcaption>Scan in WeChat</figcaption></figure></article>
      <article class="about-channel-card" id="cooperate"><p class="eyebrow">COLLABORATE</p><h3>Contact<br />Black</h3><p>Speaking, co-hosting, brand and editorial work</p><figure><img src="/images/connect/wechat-cooperation-qr.png" alt="Black’s WeChat QR code" /><figcaption>Scan in WeChat</figcaption></figure></article>
      <a class="about-channel-card about-channel-link" href="https://github.com/Code-T" target="_blank" rel="noopener noreferrer"><p class="eyebrow">OPEN SOURCE</p><h3>GitHub<br />Code-T</h3><p>Open-source projects and community resources</p><span>Open profile ↗</span></a>
      <a class="about-channel-card about-channel-link" href="https://space.bilibili.com/488340243" target="_blank" rel="noopener noreferrer"><p class="eyebrow">VIDEO</p><h3>bilibili<br />T Salon</h3><p>Event videos and community recordings</p><span>Open channel ↗</span></a>
    </div></div></section>
  </main>
</BaseLayout>
