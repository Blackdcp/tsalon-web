---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const articles = await getCollection('articlesEn', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { id: article.id }, props: { article } }));
}
const { article } = Astro.props as { article: CollectionEntry<'articlesEn'> };
const { Content, headings } = await render(article);
const all = (await getCollection('articlesEn', ({ data }) => !data.draft)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const index = all.findIndex((item) => item.id === article.id);
const previous = index > 0 ? all[index - 1] : undefined;
const next = index < all.length - 1 ? all[index + 1] : undefined;
const labels: Record<string, string> = { news: 'Community news', interview: 'Interview', 'field-note': 'Field note', guide: 'Practitioner viewpoint', archive: 'Archive' };
const jsonLd = { '@context': 'https://schema.org', '@type': 'Article', headline: article.data.title, description: article.data.summary, datePublished: article.data.publishedAt.toISOString(), dateModified: (article.data.updatedAt ?? article.data.publishedAt).toISOString(), url: new URL(`/en/articles/${article.id}/`, Astro.site).toString(), image: new URL(article.data.cover, Astro.site).toString(), author: { '@type': 'Organization', name: 'T Salon Editorial' }, publisher: { '@type': 'Organization', name: 'T Salon' }, inLanguage: 'en', about: article.data.topics };
---
<BaseLayout locale="en" alternatePath={`/articles/${article.data.translationOf}/`} title={article.data.seo.title} description={article.data.seo.description} image={article.data.cover} noindex={article.data.seo.noindex} jsonLd={jsonLd}>
  <main class="content-detail-page">
    <nav class="content-detail-shell content-detail-breadcrumb" aria-label="Breadcrumb"><a href="/en/articles/">Stories</a><span aria-hidden="true">/</span><span>{labels[article.data.type]}</span></nav>
    <header class="content-detail-shell content-detail-header"><div class="content-detail-kicker"><p class="eyebrow">{labels[article.data.type]} / T SALON</p><span class="mono">EDITORIAL</span></div><h1>{article.data.title}</h1><p class="content-detail-summary">{article.data.summary}</p><div class="content-detail-byline"><span class="content-detail-avatar" aria-hidden="true">TS</span><div><strong>T Salon Editorial</strong><span>{article.data.publishedAt.toISOString().slice(0, 10)} · {article.data.readingMinutes} min read</span></div></div></header>
    <figure class="content-detail-shell content-detail-cover"><div><img src={article.data.cover} alt={article.data.coverAlt} /></div><figcaption class="mono">T SALON / COMMUNITY ARCHIVE</figcaption></figure>
    <section class="content-detail-shell content-detail-body">
      <article class="prose content-detail-prose">
        <Content />
        <footer class="content-detail-tags"><span class="mono">TOPICS</span><div class="tag-list">{article.data.topics.map((topic) => <span class="tag">{topic}</span>)}</div></footer>
      </article>
      <aside class="content-detail-aside">
        {headings.some((heading) => heading.depth === 2) && <div class="content-detail-aside-section"><strong class="mono">ON THIS PAGE</strong><nav aria-label="On this page">{headings.filter((heading) => heading.depth === 2).map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}</nav></div>}
        <div class="content-detail-aside-section"><strong class="mono">ARTICLE INFO</strong><dl><div><dt>TYPE</dt><dd>{labels[article.data.type]}</dd></div><div><dt>PUBLISHED</dt><dd>{article.data.publishedAt.toISOString().slice(0, 10)}</dd></div><div><dt>READING TIME</dt><dd>{article.data.readingMinutes} minutes</dd></div></dl></div>
        {article.data.citations.map((citation) => <a class="content-detail-source" href={citation.url} target="_blank" rel="noopener noreferrer">{citation.label} <span>↗</span></a>)}
      </aside>
    </section>
    <nav class="content-pagination" aria-label="Article navigation"><div class="content-detail-shell content-pagination-inner">{previous ? <a class="content-pagination-item content-pagination-previous" href={`/en/articles/${previous.id}/`}><span>← Previous</span><strong>{previous.data.title}</strong></a> : <span></span>}<a class="content-pagination-back" href="/en/articles/">All stories</a>{next ? <a class="content-pagination-item content-pagination-next" href={`/en/articles/${next.id}/`}><span>Next →</span><strong>{next.data.title}</strong></a> : <span></span>}</div></nav>
  </main>
</BaseLayout>
