---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
const articles = (await getCollection('articlesEn', ({ data }) => !data.draft)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const leadArticle = articles[0];
const recentArticles = articles.slice(1);
const labels: Record<string, string> = { news: 'Community news', insight: 'Industry insight', interview: 'Interview', 'field-note': 'Field note', guide: 'Practitioner viewpoint', archive: 'Archive' };
---
<BaseLayout locale="en" alternatePath="/articles/" title="Stories — T Salon" description="Read field notes, practitioner viewpoints, interviews and industry observations from the T Salon developer community." image="/icon-512x512.png">
  <main class="content-index-page">
    <header class="content-editorial-hero"><div class="content-index-shell content-editorial-hero-inner"><div class="content-editorial-mark" aria-hidden="true"><span>&lt;</span><i></i><span>&gt;</span></div><div class="content-editorial-copy"><p class="eyebrow">STORIES / PEOPLE, PRACTICE & CHANGE</p><h1 class="display-lines"><span>Start with practice</span><span>Understand how technology happens</span></h1><p>We publish practitioner viewpoints, industry observations, interviews and field notes about how technology enters products, teams and the real world.</p></div></div></header>
    <div class="content-index-shell content-scope" aria-label="Editorial scope"><span class="mono">EDITORIAL SCOPE</span><span>Practitioner viewpoints</span><span>Industry observations</span><span>Interviews</span><span>Field notes</span></div>
    {leadArticle && <section class="content-index-shell content-lead" aria-labelledby="content-lead-title"><figure class="content-lead-media"><img src={leadArticle.data.cover} alt={leadArticle.data.coverAlt} loading="eager" /><figcaption class="mono">FROM THE ARCHIVE / T SALON</figcaption></figure><div class="content-lead-copy"><div><p class="eyebrow">LATEST / {labels[leadArticle.data.type]}</p><h2 id="content-lead-title">{leadArticle.data.title}</h2><a class="content-lead-link" href={`/en/articles/${leadArticle.id}/`}>Read the story <span aria-hidden="true">→</span></a></div><div class="content-lead-side"><p>{leadArticle.data.summary}</p><div class="content-lead-meta mono"><span>{leadArticle.data.publishedAt.toISOString().slice(0, 10).replaceAll('-', '.')}</span><span>{leadArticle.data.readingMinutes} MIN READ</span></div></div></div></section>}
    <section class="content-published" aria-labelledby="recent-content-title"><div class="content-index-shell"><header class="content-published-head"><div><p class="mono">RECENTLY PUBLISHED</p><h2 id="recent-content-title">More from T Salon</h2></div><p>Every story is edited before publication and keeps a clear source and context.</p></header><div class="content-published-list">{recentArticles.map((article, index) => <a href={`/en/articles/${article.id}/`}><span class="content-published-number mono">{String(index + 1).padStart(2, '0')}</span><div><p class="mono">{labels[article.data.type]} · {article.data.publishedAt.toISOString().slice(0, 10).replaceAll('-', '.')}</p><h3>{article.data.title}</h3><p>{article.data.summary}</p></div><span class="content-published-arrow" aria-hidden="true">→</span></a>)}</div></div></section>
  </main>
</BaseLayout>
