---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const events = await getCollection('eventsEn', ({ data }) => !data.draft);
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}
const { event } = Astro.props as { event: CollectionEntry<'eventsEn'> };
const { Content } = await render(event);
const ended = event.data.endDate.getTime() < Date.now() || event.data.registration.status === 'archived';
const date = event.data.startDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric', timeZone: event.data.timezone });
const jsonLd = { '@context': 'https://schema.org', '@type': 'Event', name: event.data.title, description: event.data.summary, startDate: event.data.startDate.toISOString(), endDate: event.data.endDate.toISOString(), eventStatus: ended ? 'https://schema.org/EventCompleted' : 'https://schema.org/EventScheduled', url: new URL(`/en/events/${event.id}/`, Astro.site).toString(), organizer: { '@type': 'Organization', name: 'T Salon', url: 'https://www.tsalon.tech/' }, image: new URL(event.data.cover, Astro.site).toString(), inLanguage: 'en', location: event.data.attendanceMode === 'online' ? { '@type': 'VirtualLocation', name: event.data.venue ?? 'T Salon Online Event', url: 'https://space.bilibili.com/488340243' } : { '@type': 'Place', name: event.data.venue ?? 'To be announced', address: { '@type': 'PostalAddress', streetAddress: event.data.address ?? '', addressLocality: event.data.city ?? 'To be announced', addressCountry: 'CN' } } };
---
<BaseLayout locale="en" alternatePath={`/events/${event.data.translationOf}/`} title={event.data.seo.title} description={event.data.seo.description} image={event.data.cover} noindex={event.data.seo.noindex} jsonLd={jsonLd}>
  <main><nav class="container breadcrumb" aria-label="Breadcrumb"><ol><li><a href="/en/">Home</a></li><li><a href="/en/events/">Events</a></li><li aria-current="page">Event details</li></ol></nav><header class="container page-title"><div class="page-title-main"><div class:list={["event-page-status", ended ? 'is-ended' : 'is-open']}><span aria-hidden="true">{ended ? '✓' : '●'}</span>{ended ? 'Ended' : 'Registration open'}</div><h1>{event.data.title}</h1><p class="lead">{event.data.summary}</p></div><div class="page-title-side"><span class="mono">EVENT / {event.data.series.toUpperCase()}</span></div><div class="page-title-main event-quickfacts"><div class="quickfact"><span class="mono">DATE</span><strong>{date}</strong></div><div class="quickfact"><span class="mono">LOCATION</span><strong>{event.data.city ?? 'Online'} · {event.data.venue ?? 'To be announced'}</strong></div><div class="quickfact"><span class="mono">FORMAT</span><strong>{event.data.attendanceMode === 'offline' ? 'In person' : event.data.attendanceMode === 'online' ? 'Online' : 'Hybrid'}</strong></div><div class="quickfact"><span class="mono">LANGUAGE</span><strong>Chinese</strong></div></div></header><figure class="container page-cover"><img src={event.data.cover} alt={event.data.coverAlt} /><figcaption class="mono">T SALON / EVENT RECORD</figcaption></figure><div class="content-container event-content"><aside class="event-index"><strong class="mono">ON THIS PAGE</strong><a href="#intro">Introduction</a>{event.data.agenda.length > 0 && <a href="#agenda">Programme</a>}</aside><div class="event-main"><section id="intro" class="content-section event-body"><Content /></section>{event.data.agenda.length > 0 && <section id="agenda" class="content-section"><h2>Programme</h2><div class="agenda">{event.data.agenda.map((item) => <div class="agenda-item"><time>{item.time}</time><div><h3>{item.title}</h3><p>{item.description}</p></div></div>)}</div></section>}</div></div></main>
</BaseLayout>
