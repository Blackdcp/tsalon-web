---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { archiveEn } from '../../../data/en';
const archiveEvents = (await getCollection('activityArchive')).sort((a, b) => a.data.order - b.data.order);
const events = (await getCollection('eventsEn', ({ data }) => !data.draft)).filter((event) => event.data.series !== 't-chat').sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---
<BaseLayout locale="en" alternatePath="/events/" title="Events — T Salon" description="Explore T Salon developer events, past gatherings and the open call for future conversations about AI and embodied intelligence." image="/icon-512x512.png">
  <main class="event-directory-page">
    <header class="event-directory-masthead"><div class="container"><div><p class="eyebrow">T SALON / EVENTS</p><h1 class="display-lines"><span>Meet people doing the work</span><span>Explain the technology</span><span>Keep the experience</span></h1></div><div class="event-directory-intro"><p>Find upcoming registrations, records from past gatherings, and technology events initiated or co-hosted by T Salon.</p><button type="button" data-open-black-qr>Propose an event <span>↗</span></button></div></div></header>
    <section class="container event-directory" aria-labelledby="event-directory-title"><header class="event-directory-heading"><div><span class="mono">01 / ALL EVENTS</span><h2 id="event-directory-title">Event directory</h2></div></header><div class="event-directory-grid">
      <a class="event-tile" href="/en/events/series/t-chat/"><figure class="event-tile-media"><img src="/images/news/tchat-launch-1.jpg" alt="T Chat series poster" loading="eager" /></figure><div class="event-tile-body"><p class="event-tile-series mono"><span>T CHAT / ONLINE</span><i class="event-tile-status is-ended">ENDED</i></p><h3>T Chat: Engineering Inside Major Technology Companies</h3><div class="event-tile-facts"><span><i>Dates</i>2022—2023</span><span><i>Format</i>Online · 17 episodes</span></div><strong class="event-tile-action">Series archive <i>→</i></strong></div></a>
      {events.map((event) => <a class="event-tile" href={`/en/events/${event.id}/`}><figure class="event-tile-media"><img src={event.data.cover} alt={event.data.coverAlt} loading="lazy" /></figure><div class="event-tile-body"><p class="event-tile-series mono"><span>{event.data.series.toUpperCase()} / {event.data.attendanceMode === 'offline' ? 'IN PERSON' : 'ONLINE'}</span><i class="event-tile-status is-ended">{event.data.endDate.getTime() < Date.now() ? 'ENDED' : 'OPEN'}</i></p><h3>{event.data.title}</h3><div class="event-tile-facts"><span><i>Date</i>{event.data.startDate.toISOString().slice(0, 10)}</span><span><i>City</i>{event.data.city ?? 'Online'}</span></div><strong class="event-tile-action">Event details <i>→</i></strong></div></a>)}
      {archiveEvents.map((event) => <a class="event-tile" href={`/en/events/archive/${event.id}/`}><figure class="event-tile-media"><img src={event.data.cover} alt={archiveEn[event.id]?.title} loading="lazy" /></figure><div class="event-tile-body"><p class="event-tile-series mono"><span>T SALON / {event.data.mode === 'online' ? 'ONLINE' : 'OFFLINE'}</span><i class="event-tile-status is-ended">ENDED</i></p><h3>{archiveEn[event.id]?.title}</h3><div class="event-tile-facts"><span><i>Date</i>{event.data.startDate.toISOString().slice(0, 10)}</span><span><i>City</i>{archiveEn[event.id]?.city}</span></div><strong class="event-tile-action">Event details <i>→</i></strong></div></a>)}
    </div></section>
    <section class="container event-collab-cta" aria-labelledby="event-topics-title"><div><p class="eyebrow">02 / NEXT · OPEN CALL</p><h2 id="event-topics-title">AI and embodied intelligence<br />help shape the next gathering</h2><p>If you are building relevant technology, products or content, bring your real practice to the room as a speaker or collaborator.</p><button class="btn btn-dark event-collab-trigger" type="button" data-open-black-qr>Take part <span>→</span></button></div><figure><img src="/images/gallery/gallery-4.jpeg" alt="A T Salon speaker presenting to developers" loading="lazy" /></figure></section>
    <dialog class="event-qr-dialog" id="black-qr-dialog" aria-labelledby="event-qr-title"><button class="event-qr-close" type="button" data-close-black-qr aria-label="Close">×</button><div class="event-qr-copy"><span class="mono">JOIN THE NEXT EVENT</span><h2 id="event-qr-title">Let’s make the next one</h2><p>To speak, co-create a topic or help host a gathering, scan the code and send Black a short note about what you are working on.</p></div><div class="event-qr-code"><div class="event-qr-crop"><img src="/images/connect/wechat-cooperation-qr.png" alt="Black’s WeChat QR code" /></div><span class="mono">WECHAT · BLACK</span></div></dialog>
    <section class="container memory-cta"><figure><img src="/images/gallery/gallery-17.jpeg" alt="Developers at an early T Salon gathering in 2016" loading="lazy" /></figure><div><p class="eyebrow">03 / COMMUNITY ARCHIVE · 2016—NOW</p><h2>The event ends<br />The room is still worth remembering</h2><p>Our year-by-year archive keeps the visible trail of a community that began with iOS developers and continued across cities.</p><a class="btn btn-dark" href="/en/history/">Open the archive <span>→</span></a></div></section>
  </main>
</BaseLayout>
<script>
  const dialog = document.querySelector<HTMLDialogElement>('#black-qr-dialog');
  let previousFocus: HTMLElement | null = null;
  document.querySelectorAll<HTMLElement>('[data-open-black-qr]').forEach((trigger) => trigger.addEventListener('click', () => { previousFocus = trigger; dialog?.showModal(); document.querySelector<HTMLElement>('[data-close-black-qr]')?.focus(); }));
  const close = () => { dialog?.close(); previousFocus?.focus(); };
  document.querySelector<HTMLElement>('[data-close-black-qr]')?.addEventListener('click', close);
  dialog?.addEventListener('click', (event) => { if (event.target === dialog) close(); });
</script>
