---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import ArchiveEventCard from '../components/ArchiveEventCard.astro';

const events = (await getCollection('events', ({ data }) => !data.draft)).filter((event) => event.data.series !== 't-chat').sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
const archiveEvents = (await getCollection('activityArchive')).sort((a, b) => a.data.order - b.data.order);
const tChat = (await getCollection('eventSeries')).find((item) => item.id === 't-chat');
const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const partners = (await getCollection('partners')).sort((a, b) => a.data.order - b.data.order);
const articleTypeLabels: Record<string, string> = { news: '社区动态', interview: '人物采访', 'field-note': '活动回顾', guide: '嘉宾观点', archive: '社区档案' };
const orgJsonLd = {
  '@context': 'https://schema.org', '@type': 'Organization', name: 'T Salon', alternateName: 'T 技术沙龙',
  url: 'https://www.tsalon.tech/', foundingDate: '2016-03',
  description: '面向开发者的线上与线下技术交流平台。',
  sameAs: ['https://github.com/Code-T', 'https://space.bilibili.com/488340243'],
};
---
<BaseLayout alternatePath="/en/" title="T Salon — 面向开发者的线上与线下技术交流" description="T Salon 始于 2016 年，通过城市沙龙、技术大会、在线访谈和长期内容，连接 Apple、AI、具身智能等领域的真实研发实践。" image="/images/home-community-group.jpg" jsonLd={orgJsonLd}>
  <main>
    <section class="container home-hero home-hero-v2">
      <div class="home-hero-copy"><p class="eyebrow">开发者社区 · 始于 2016</p><h1 class="display-lines"><span>技术发生在实践里</span><span>社区让经验流动起来</span></h1><p>面向开发者的线上 & 线下技术交流平台。从 iOS 开发者社区出发，持续连接 Apple 生态、AI 与具身智能的一线实践。</p><div class="hero-actions"><a class="btn btn-dark" href="/events/">探索活动 <span>↗</span></a><a class="btn btn-outline" href="/articles/">阅读内容</a></div></div>
      <figure class="home-hero-media"><img src="/images/home-community-group.webp" srcset="/images/home-community-group-960.webp 960w, /images/home-community-group.webp 1519w" sizes="(max-width: 1000px) 100vw, 50vw" width="1519" height="879" alt="T Salon 开发者社区活动大合照" fetchpriority="high" decoding="async" /><span class="code-mark" aria-hidden="true">&lt;<i></i>&gt;</span><figcaption class="mono">线上与线下 · 由开发者共同建设</figcaption></figure>
    </section>

    <div class="container home-proof"><span class="mono">始于 2016</span><strong>100+ 线下活动</strong><strong>10万+ 开发者</strong><strong>50+ 合作伙伴</strong><a href="/history/">查看九年社区年鉴 →</a></div>

    <section class="home-series">
      <div class="container">
        <header class="section-heading"><span class="mono">01 / 活动</span><h2>和真正做事的人见面<br />把经验留在现场之后</h2><a class="text-link" href="/events/">查看全部活动 <span>→</span></a></header>
        <p class="section-intro">线下活动、线上对谈与长期主题共同构成 T Salon 的活动目录。报名、详情与结束后的回顾，都从这里进入。</p>
        <div class="event-directory-grid home-event-grid">
          {events[0] ? <EventCard event={events[0]} /> : archiveEvents[0] && <ArchiveEventCard event={archiveEvents[0]} />}
          {tChat && <a class="event-tile" href="/events/series/t-chat/"><figure class="event-tile-media"><img src={tChat.data.cover} alt={tChat.data.coverAlt} loading="lazy" /></figure><div class="event-tile-body"><p class="event-tile-series mono"><span>T CHAT / 线上</span><i class="event-tile-status is-ended">已结束</i></p><h3>T Chat「我在大厂做研发」完整回顾</h3><div class="event-tile-facts"><span><i>日期</i>2022—2023</span><span><i>形式</i>线上 · 17 期</span></div><strong class="event-tile-action">系列回顾 <i>→</i></strong></div></a>}
          <a class="event-tile home-open-call" href="/events/#event-topics-title"><figure class="event-tile-media"><img src="/images/gallery/gallery-4.jpeg" alt="T Salon 技术活动现场，开发者正在听嘉宾分享" loading="lazy" /></figure><div class="event-tile-body"><p class="event-tile-series mono"><span>下一场 / 公开招募</span><i class="event-tile-status is-open">开放中</i></p><h3>AI 与具身智能，寻找下一场的分享者</h3><p>欢迎研发、产品与内容实践者成为嘉宾或参与共创。</p><strong class="event-tile-action">了解下一场 <i>→</i></strong></div></a>
        </div>
      </div>
    </section>

    <section class="home-editorial">
      <div class="container">
        <header class="section-heading"><span class="mono">02 / 内容</span><h2>从一线实践出发<br />理解技术如何发生</h2><a class="text-link" href="/articles/">进入内容中心 <span>→</span></a></header>
        {articles[0] && <a class="home-editorial-feature" href={`/articles/${articles[0].id}/`}><figure><img src={articles[0].data.cover} alt={articles[0].data.coverAlt} loading="lazy" /><figcaption class="mono">最新 / {articleTypeLabels[articles[0].data.type] ?? '内容'}</figcaption></figure><div><p class="eyebrow">本期内容</p><h3>{articles[0].data.title}</h3><p>{articles[0].data.summary}</p><span>阅读文章 <i>→</i></span></div></a>}
        <div class="home-editorial-scope"><p>我们持续发布嘉宾观点、行业观察、人物采访与活动回顾。</p><div><span>嘉宾观点</span><span>行业观察</span><span>人物采访</span><span>活动回顾</span></div></div>
      </div>
    </section>

    <section class="home-archive-showcase">
      <div class="container"><figure><img src="/images/gallery/gallery-12.jpeg" alt="2017 年 T Salon 与饿了么合作活动现场" loading="lazy" /></figure><div><p class="eyebrow">03 / 社区年鉴 · 2016 至今</p><h2>我们办了很多年<br />不只是一句介绍</h2><p>从 iOS 开发者的第一次相聚，到不同城市的一场场技术交流，照片留下了社区共同走过的路。</p><a class="btn btn-light" href="/history/">打开社区年鉴 <span>→</span></a></div></div>
    </section>

    <section class="container home-partners">
      <header class="section-heading"><span class="mono">04 / 社区伙伴</span><h2>社区从来不是独立完成的</h2><a class="text-link" href="/about/">了解我们 <span>→</span></a></header>
      <div class="home-partner-logo-grid">{partners.map((partner) => <figure><img src={partner.data.logo} alt={partner.data.logoAlt} loading="lazy" /><figcaption class="sr-only">{partner.data.name}</figcaption></figure>)}</div>
    </section>
  </main>
</BaseLayout>
